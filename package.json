{
  "name": "projects-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname localhost --port 3000",
    "ai:deploy": "bunx wrangler deploy -c workers/ai-worker/wrangler.toml",
    "ai:dev": "bunx wrangler dev -c workers/ai-worker/wrangler.toml",
    "ai:whoami": "bunx wrangler whoami",
    "appwrite:keepalive": "bun run scripts/appwrite-console-heartbeat.ts",
    "build": "next build",
    "deploy": "bunx vercel deploy --prod",
    "start": "next start",
    "lint": "biome check",
    "format": "biome format --write",
    "db:provision": "bun run scripts/provision-appwrite.ts"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.0.0",
    "@hugeicons/react": "^1.1.5",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "next": "16.2.4",
    "next-auth": "^4.24.13",
    "node-appwrite": "^22.1.3",
    "radix-ui": "^1.4.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "shadcn": "4.2.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
