{
  "name": "projects-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --hostname localhost --port 3000",
    "ai:deploy": "bunx wrangler deploy -c workers/ai-worker/wrangler.toml",
    "ai:dev": "bunx wrangler dev -c workers/ai-worker/wrangler.toml",
    "ai:whoami": "bunx wrangler whoami",
    "appwrite:keepalive": "bun run scripts/appwrite-console-heartbeat.ts",
    "appwrite:check": "bun run scripts/check-migration.ts",
    "appwrite:compare": "bun run scripts/compare-databases.ts",
    "appwrite:clear-local": "bun run scripts/clear-local-db.ts",
    "appwrite:migrate": "bun run scripts/migrate-appwrite.ts",
    "build": "next build",
    "deploy": "bunx vercel deploy --prod",
    "start": "next start",
    "lint": "biome lint",
    "format": "biome format --write",
    "db:provision": "bun run scripts/provision-appwrite.ts"
  },
  "dependencies": {
    "@hugeicons/core-free-icons": "^4.1.2",
    "@hugeicons/react": "^1.1.6",
    "@types/three": "^0.184.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "exceljs": "^4.4.0",
    "leo-profanity": "^1.9.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-auth": "^4.24.14",
    "node-appwrite": "^24.1.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "server-only": "^0.0.1",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^25.6.2",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3"
  },
  "ignoreScripts": [
    "sharp",
    "unrs-resolver"
  ],
  "trustedDependencies": [
    "sharp",
    "unrs-resolver"
  ]
}
